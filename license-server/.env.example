PORT=3000
HOST=127.0.0.1
DB_PATH=./data/netclaw-license.db
LOG_LEVEL=info
NODE_ENV=production

# 64+ hex chars; used for Bearer auth on legacy /api/admin/* (super-admin token)
ADMIN_SECRET=change_me_long_random_hex

# 64+ hex chars; signs license activation JWTs (issued to netclaw-agent clients).
JWT_SECRET=change_me_jwt_signing_secret

# 64+ hex chars; signs admin web-UI session cookies. Distinct from JWT_SECRET.
SESSION_JWT_SECRET=change_me_session_signing_secret

# Comma-separated allowed Origins for cookie-auth POST/PATCH/DELETE.
# Empty = strict same-origin. When fronting via Caddy, set to:
#   https://license.netclawsec.com,http://120.55.247.72
ALLOWED_ORIGINS=

# Default secure cookie behavior is NODE_ENV=production. Override with this:
# SESSION_COOKIE_SECURE=true
