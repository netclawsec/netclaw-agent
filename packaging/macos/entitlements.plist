<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Hardened Runtime entitlements for NetClaw Agent.app

        Why each key is needed:
        - allow-jit / allow-unsigned-executable-memory: Python interpreter +
          ctypes / cffi loaded shared objects trigger these checks.
        - disable-library-validation: PyInstaller bundles libraries signed
          by us, not Apple. Needed when loading bundled .dylibs.
        - network.client: calling external LLM APIs (OpenAI/Anthropic/NetClaw
          relay).
        - network.server: uvicorn binds 127.0.0.1:9119 for the embedded webui.
        - files.user-selected.read-write: tools need to read user files via
          standard Open/Save dialogs.
        - files.downloads: saving generated artifacts to ~/Downloads.
        - cs.allow-dyld-environment-variables: PyInstaller bootloader sets
          DYLD_LIBRARY_PATH at startup.

        NOT included (intentional):
        - App Sandbox (com.apple.security.app-sandbox): incompatible with
          arbitrary Python imports + subprocess tools. We rely on Gatekeeper
          + notarization instead.
        - Camera / Microphone / Location: not used by the core app. If the
          [voice] extra is bundled later, add NSMicrophoneUsageDescription
          to Info.plist and the matching entitlement here.
    -->

    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <key>com.apple.security.network.client</key>
    <true/>

    <key>com.apple.security.network.server</key>
    <true/>

    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
