# Copy this file to .env.signing and fill in real values.
# build.sh sources this file automatically.
# .env.signing is gitignored — DO NOT commit real credentials.

# ---------------------------------------------------------------------------
# Apple Developer account credentials
# ---------------------------------------------------------------------------

# Apple ID (email) that owns the Developer ID Application certificate.
APPLE_ID="your-apple-id@example.com"

# App-specific password generated at https://appleid.apple.com/account/manage
# (Security → App-Specific Passwords). NOT your main Apple ID password.
APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Developer Team ID from https://developer.apple.com/account (Membership page).
APPLE_TEAM_ID="G92A987222"

# ---------------------------------------------------------------------------
# Signing identity (common name of the cert — must be installed in login keychain)
# ---------------------------------------------------------------------------

# Verify with:
#   security find-identity -p codesigning -v
SIGNING_IDENTITY="Developer ID Application: jianhan ma (G92A987222)"

# ---------------------------------------------------------------------------
# Optional stage skips (set to 1 to skip)
# ---------------------------------------------------------------------------

# SKIP_WEBUI_BUILD=1      # reuse existing web_dist/
# SKIP_SIGN=1             # produce unsigned .app (local debugging only)
# SKIP_DMG=1              # produce .app only, skip DMG + notarize + staple
# SKIP_NOTARIZE=1         # produce signed DMG but skip notarization
# FORCE_ICON=1            # regenerate .icns even if newer than source
